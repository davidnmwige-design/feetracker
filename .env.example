# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Authentication ───────────────────────────────────────────────────────────
# Used by NextAuth to sign session tokens. Must be at least 32 characters.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="replace-with-a-random-secret-at-least-32-chars"
AUTH_SECRET="replace-with-a-random-secret"

# The public URL of your deployment (no trailing slash)
# Change this to your custom domain when you go live e.g. https://elimupay.co.ke
NEXTAUTH_URL="https://feetracker.co.ke"

# The public app URL used in client-side code (no trailing slash)
# Update this to your custom domain when you go live e.g. https://elimupay.co.ke
NEXT_PUBLIC_APP_URL="https://feetracker-seven.vercel.app"

# ─── Email (Gmail SMTP) ───────────────────────────────────────────────────────
# The Gmail address Elimu Pay sends from.
# Use a dedicated Gmail account or Google Workspace address for this.
# NOTE: Update this to support@elimupay.co.ke when the domain is purchased.
EMAIL_USER="support@feetracker.co.ke"

# A Gmail App Password — NOT your regular Gmail password.
# Generate one at: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be enabled on the Gmail account)
EMAIL_PASS="xxxx-xxxx-xxxx-xxxx"

# ─── Admin ────────────────────────────────────────────────────────────────────
# Email address that gets admin access at /admin/dashboard
ADMIN_EMAIL="admin@feetracker.co.ke"

# Email address that receives admin platform notifications (signups, upgrades, backups)
ADMIN_NOTIFICATION_EMAIL="admin@feetracker.co.ke"

# Secret key required to create the first admin account at /api/admin/setup
ADMIN_SECRET_KEY="replace-with-a-long-random-secret"

# ─── Encryption ───────────────────────────────────────────────────────────────
# AES-256 field-level encryption key — must be exactly 32 characters.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex').slice(0,32))"
# REQUIRED in production. Without this, sensitive fields (parentEmail) are stored as plaintext.
# Add this to Vercel → Project Settings → Environment Variables.
DATA_ENCRYPTION_KEY="your_32_character_random_string_here"

# ─── Safaricom Daraja API (real-time MPESA notifications) ────────────────────
# Get these from https://developer.safaricom.co.ke → My Apps
# Leave blank to disable Daraja integration.
DARAJA_CONSUMER_KEY=get_from_developer.safaricom.co.ke
DARAJA_CONSUMER_SECRET=get_from_developer.safaricom.co.ke
# Set to "production" when going live; leave as "sandbox" for testing
DARAJA_ENV=sandbox

# ─── Upstash Redis (optional caching) ────────────────────────────────────────
# Create a free Redis database at upstash.com → copy REST URL and token
# If not set, caching is disabled gracefully (no errors)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ─── Sentry (optional error tracking) ────────────────────────────────────────
# Create a Next.js project at sentry.io → copy DSN
SENTRY_DSN=https://your-key@sentry.io/project-id
NEXT_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/project-id

# ─── Crisp Chat (optional support chat) ──────────────────────────────────────
# Create account at crisp.chat → Settings → Website → copy Website ID
NEXT_PUBLIC_CRISP_WEBSITE_ID=your-crisp-website-id

# ─── Plausible Analytics (optional) ──────────────────────────────────────────
# Create account at plausible.io → add your domain
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=elimupay.co.ke

# ─── Staging ──────────────────────────────────────────────────────────────────
# Set to "true" on staging Vercel environment to show the red staging banner
NEXT_PUBLIC_IS_STAGING=false
