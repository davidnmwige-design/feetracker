generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model School {
  id        Int       @id @default(autoincrement())
  name      String
  paybill   String?
  term      String    @default("Term 2 2026")
  createdAt DateTime  @default(now())
  students  Student[]
}

model Student {
  id          Int       @id @default(autoincrement())
  name        String
  admNo       String    @unique
  class       String
  stream      String?
  parentName  String?
  parentPhone String?
  feeRequired Float     @default(0)
  createdAt   DateTime  @default(now())
  schoolId    Int
  school      School    @relation(fields: [schoolId], references: [id])
  payments    Payment[]
}

model Payment {
  id          Int      @id @default(autoincrement())
  mpesaRef    String?
  amount      Float
  paidAt      DateTime @default(now())
  senderName  String?
  senderPhone String?
  matched     Boolean  @default(false)
  notified    Boolean  @default(false)
  studentId   Int?
  student     Student? @relation(fields: [studentId], references: [id])
}