generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int          @id @default(autoincrement())
  name               String
  email              String       @unique
  password           String
  isAdmin            Boolean      @default(false)
  sessionVersion     Int          @default(1)
  twoFactorEnabled   Boolean      @default(false)
  createdAt          DateTime     @default(now())
  school             School?
  schoolUsers        SchoolUser[]
  otpCodes           OTPCode[]
}

model OTPCode {
  id        Int      @id @default(autoincrement())
  userId    Int
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model School {
  id                  Int                  @id @default(autoincrement())
  name                String
  paybill             String?
  accountNumberFormat String?
  replyToEmail        String?
  emailSignature      String?
  whatsappNumber      String?
  currentTerm         String               @default("Term 1 2026")
  currentPlan         String               @default("Starter")
  createdAt           DateTime             @default(now())
  trialEndsAt             DateTime?
  trialExpiryNotified     Boolean              @default(false)
  penaltyEnabled      Boolean              @default(false)
  penaltyType         String               @default("fixed")
  penaltyAmount       Float                @default(0)
  penaltyDueDate      Int                  @default(15)
  userId              Int                  @unique
  user                User                 @relation(fields: [userId], references: [id])
  students            Student[]
  terms               Term[]
  payments            Payment[]
  upgradeRequests     PlanUpgradeRequest[]
  notes               SchoolNote[]
  billingRecords      BillingRecord[]
  invoices            Invoice[]
  contract            Contract?
  schoolUsers         SchoolUser[]
  reminderSchedule    ReminderSchedule?
}

model SchoolUser {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  userId    Int
  role      String   @default("viewer")
  createdAt DateTime @default(now())
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([schoolId, userId])
}

model PlanUpgradeRequest {
  id            Int      @id @default(autoincrement())
  schoolId      Int
  currentPlan   String
  requestedPlan String
  status        String   @default("pending")
  notes         String?
  createdAt     DateTime @default(now())
  school        School   @relation(fields: [schoolId], references: [id])
}

model Term {
  id        Int       @id @default(autoincrement())
  name      String
  createdAt DateTime  @default(now())
  archived  Boolean   @default(false)
  schoolId  Int
  school    School    @relation(fields: [schoolId], references: [id])
  payments  Payment[]
}

model Student {
  id           Int          @id @default(autoincrement())
  name         String
  admNo        String
  class        String
  stream       String?
  parentName   String?
  parentPhone  String?
  parentEmail  String?
  parent2Name  String?
  parent2Phone String?
  parent2Email String?
  feeRequired  Float        @default(0)
  tuitionFee   Float        @default(0)
  sportsFee    Float        @default(0)
  clubsFee     Float        @default(0)
  otherFee     Float        @default(0)
  createdAt    DateTime     @default(now())
  schoolId     Int
  school       School       @relation(fields: [schoolId], references: [id])
  payments     Payment[]
  invoices     Invoice[]
  feeCategories FeeCategory[]

  @@unique([admNo, schoolId])
}

model FeeCategory {
  id        Int     @id @default(autoincrement())
  studentId Int
  name      String
  amount    Float
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Payment {
  id          Int      @id @default(autoincrement())
  mpesaRef    String?
  amount      Float
  paidAt      DateTime @default(now())
  senderName  String?
  senderPhone String?
  matched     Boolean  @default(false)
  notified    Boolean  @default(false)
  source      String   @default("upload")
  studentId   Int?
  termId      Int?
  schoolId    Int?
  student     Student? @relation(fields: [studentId], references: [id])
  term        Term?    @relation(fields: [termId], references: [id])
  school      School?  @relation(fields: [schoolId], references: [id])
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SchoolNote {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  content   String
  createdAt DateTime @default(now())
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model BillingRecord {
  id       Int       @id @default(autoincrement())
  schoolId Int
  month    Int
  year     Int
  isPaid   Boolean   @default(false)
  paidAt   DateTime?
  amount   Float
  school   School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, month, year])
}

model Invoice {
  id        Int       @id @default(autoincrement())
  studentId Int
  schoolId  Int
  term      String
  status    String    @default("draft")
  sentAt    DateTime?
  amount    Float
  breakdown Json
  createdAt DateTime  @default(now())
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([studentId, term])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  schoolId  Int?
  action    String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
}

model Contract {
  id         Int      @id @default(autoincrement())
  schoolId   Int      @unique
  fileName   String
  fileSize   Int
  fileData   Bytes
  uploadedAt DateTime @default(now())
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model ReminderSchedule {
  id           Int       @id @default(autoincrement())
  schoolId     Int       @unique
  enabled      Boolean   @default(false)
  frequency    String    @default("weekly")
  dayOfWeek    Int       @default(1)
  dayOfMonth   Int       @default(1)
  time         String    @default("08:00")
  lastSentAt   DateTime?
  createdAt    DateTime  @default(now())
  school       School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model PlatformSettings {
  id              Int     @id @default(1)
  trialDays       Int     @default(30)
  defaultPlan     String  @default("Starter")
  maintenanceMode Boolean @default(false)
  announcement    String  @default("")
  notifyNewSchool      Boolean @default(true)
  notifyTrialExpiry    Boolean @default(true)
  notifyUpgradeRequest Boolean @default(true)
  notifyAccountDeleted Boolean @default(true)
  companyName     String  @default("Elimu Pay")
  adminName       String  @default("David Njiru")
  companyAddress  String  @default("")
  kraPin          String  @default("")
  startingInvoiceNumber Int @default(1000)
  invoiceDueDays  Int     @default(30)
  lateInterestRate Float  @default(0)
  emailSignature  String  @default("")
}

model AdminAnnouncement {
  id            Int      @id @default(autoincrement())
  subject       String
  message       String
  recipientType String   @default("all")
  recipientCount Int     @default(0)
  sentBy        String
  createdAt     DateTime @default(now())
}
