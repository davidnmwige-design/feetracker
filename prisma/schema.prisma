generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  school    School?
}

model School {
  id          Int       @id @default(autoincrement())
  name        String
  paybill     String?
  currentTerm String    @default("Term 1 2026")
  createdAt   DateTime  @default(now())
  userId      Int       @unique
  user        User      @relation(fields: [userId], references: [id])
  students    Student[]
  terms       Term[]
}

model Term {
  id        Int       @id @default(autoincrement())
  name      String
  createdAt DateTime  @default(now())
  archived  Boolean   @default(false)
  schoolId  Int
  school    School    @relation(fields: [schoolId], references: [id])
  payments  Payment[]
}

model Student {
  id          Int       @id @default(autoincrement())
  name        String
  admNo       String
  class       String
  stream      String?
  parentName  String?
  parentPhone String?
  feeRequired Float     @default(0)
  createdAt   DateTime  @default(now())
  schoolId    Int
  school      School    @relation(fields: [schoolId], references: [id])
  payments    Payment[]

  @@unique([admNo, schoolId])
}

model Payment {
  id          Int      @id @default(autoincrement())
  mpesaRef    String?
  amount      Float
  paidAt      DateTime @default(now())
  senderName  String?
  senderPhone String?
  matched     Boolean  @default(false)
  notified    Boolean  @default(false)
  studentId   Int?
  termId      Int?
  student     Student? @relation(fields: [studentId], references: [id])
  term        Term?    @relation(fields: [termId], references: [id])
}