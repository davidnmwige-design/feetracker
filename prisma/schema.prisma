generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   Int          @id @default(autoincrement())
  name                 String
  email                String       @unique
  password             String
  isAdmin              Boolean      @default(false)
  sessionVersion       Int          @default(1)
  twoFactorEnabled     Boolean      @default(false)
  failedLoginAttempts  Int          @default(0)
  lockedUntil          DateTime?
  createdAt            DateTime     @default(now())
  school               School?
  schoolUsers          SchoolUser[]
  otpCodes             OTPCode[]

  @@index([isAdmin])
}

model OTPCode {
  id        Int      @id @default(autoincrement())
  userId    Int
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model School {
  id                  Int                  @id @default(autoincrement())
  name                String
  paybill             String?
  accountNumberFormat String?
  replyToEmail        String?
  emailSignature      String?
  whatsappNumber      String?
  currentTerm         String               @default("Term 1 2026")
  currentPlan         String               @default("Starter")
  billingCycle        String               @default("monthly")
  createdAt           DateTime             @default(now())
  trialEndsAt             DateTime?
  trialExpiryNotified     Boolean              @default(false)
  penaltyEnabled      Boolean              @default(false)
  penaltyType         String               @default("fixed")
  penaltyAmount       Float                @default(0)
  penaltyDueDate      Int                  @default(15)
  logoUrl             String?
  brandColor          String?              @default("#c8a84b")
  schoolMotto         String?
  userId              Int                  @unique
  user                User                 @relation(fields: [userId], references: [id])
  students            Student[]
  terms               Term[]
  payments            Payment[]
  upgradeRequests     PlanUpgradeRequest[]
  notes               SchoolNote[]
  billingRecords      BillingRecord[]
  invoices            Invoice[]
  contract            Contract?
  schoolUsers         SchoolUser[]
  reminderSchedule    ReminderSchedule?
  feeDiscounts        FeeDiscount[]
  academicYears       AcademicYear[]
  examFees            ExamFee[]
  testimonial         Testimonial?
  testimonialRequestSent Boolean @default(false)
  nextInvoiceNumber   Int                  @default(1000)

  @@unique([paybill])
  @@index([currentPlan])
}

model SchoolUser {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  userId    Int
  role      String   @default("viewer")
  createdAt DateTime @default(now())
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([schoolId, userId])
  @@index([userId])
  @@index([schoolId])
}

model PlanUpgradeRequest {
  id            Int      @id @default(autoincrement())
  schoolId      Int
  currentPlan   String
  requestedPlan String
  status        String   @default("pending")
  notes         String?
  createdAt     DateTime @default(now())
  school        School   @relation(fields: [schoolId], references: [id])
}

model Term {
  id        Int       @id @default(autoincrement())
  name      String
  createdAt DateTime  @default(now())
  archived  Boolean   @default(false)
  schoolId  Int
  school    School    @relation(fields: [schoolId], references: [id])
  payments  Payment[]
}

model Student {
  id               Int               @id @default(autoincrement())
  name             String
  admNo            String
  class            String
  stream           String?
  parentName       String?
  parentPhone      String?
  parentEmail      String?
  parent2Name      String?
  parent2Phone     String?
  parent2Email     String?
  parentPhoneHash  String?
  parent2PhoneHash String?
  photoUrl         String?
  feeRequired      Float             @default(0)
  tuitionFee       Float             @default(0)
  sportsFee        Float             @default(0)
  clubsFee         Float             @default(0)
  otherFee         Float             @default(0)
  createdAt        DateTime          @default(now())
  schoolId         Int
  school           School            @relation(fields: [schoolId], references: [id])
  payments         Payment[]
  invoices         Invoice[]
  feeCategories    FeeCategory[]
  bursary          Bursary?
  studentDiscounts StudentDiscount[]
  studentExamFees  StudentExamFee[]

  @@unique([admNo, schoolId])
  @@index([schoolId])
  @@index([schoolId, class])
  @@index([parentPhone])
  @@index([schoolId, parentPhone])
  @@index([parentPhoneHash])
}

model Bursary {
  id            Int       @id @default(autoincrement())
  studentId     Int       @unique
  type          String
  description   String?
  discountType  String
  discountValue Float
  approvedBy    String?
  startDate     DateTime  @default(now())
  endDate       DateTime?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  student       Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([active])
}

model FeeCategory {
  id        Int     @id @default(autoincrement())
  studentId Int
  name      String
  amount    Float
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model Payment {
  id          Int      @id @default(autoincrement())
  mpesaRef    String?
  amount      Float
  paidAt      DateTime @default(now())
  senderName  String?
  senderPhone String?
  matched     Boolean  @default(false)
  notified    Boolean  @default(false)
  source      String   @default("upload")
  studentId   Int?
  termId      Int?
  schoolId    Int?
  student     Student? @relation(fields: [studentId], references: [id])
  term        Term?    @relation(fields: [termId], references: [id])
  school      School?  @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([studentId])
  @@index([mpesaRef])
  @@index([schoolId, matched])
  @@index([paidAt])
  @@index([source])
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SchoolNote {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  content   String
  createdAt DateTime @default(now())
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model BillingRecord {
  id       Int       @id @default(autoincrement())
  schoolId Int
  month    Int
  year     Int
  isPaid   Boolean   @default(false)
  paidAt   DateTime?
  amount   Float
  school   School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, month, year])
}

model Invoice {
  id        Int       @id @default(autoincrement())
  studentId Int
  schoolId  Int
  term      String
  status    String    @default("draft")
  sentAt    DateTime?
  amount        Float
  breakdown     Json
  invoiceNumber Int?
  createdAt DateTime  @default(now())
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([studentId, term])
  @@index([schoolId])
  @@index([schoolId, status])
  @@index([status])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  schoolId  Int?
  action    String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([schoolId])
  @@index([userId])
  @@index([createdAt])
}

model Contract {
  id         Int      @id @default(autoincrement())
  schoolId   Int      @unique
  fileName   String
  fileSize   Int
  fileData   Bytes
  uploadedAt DateTime @default(now())
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model ReminderSchedule {
  id           Int       @id @default(autoincrement())
  schoolId     Int       @unique
  enabled      Boolean   @default(false)
  frequency    String    @default("weekly")
  dayOfWeek    Int       @default(1)
  dayOfMonth   Int       @default(1)
  time         String    @default("08:00")
  lastSentAt   DateTime?
  createdAt    DateTime  @default(now())
  school       School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([enabled])
}

model PlatformSettings {
  id              Int     @id @default(1)
  trialDays       Int     @default(30)
  defaultPlan     String  @default("Starter")
  maintenanceMode Boolean @default(false)
  announcement    String  @default("")
  notifyNewSchool      Boolean @default(true)
  notifyTrialExpiry    Boolean @default(true)
  notifyUpgradeRequest Boolean @default(true)
  notifyAccountDeleted Boolean @default(true)
  companyName     String  @default("Elimu Pay")
  adminName       String  @default("David Njiru")
  companyAddress  String  @default("")
  kraPin          String  @default("")
  startingInvoiceNumber Int @default(1000)
  invoiceDueDays  Int     @default(30)
  lateInterestRate Float  @default(0)
  emailSignature  String  @default("")
}

model AdminAnnouncement {
  id            Int      @id @default(autoincrement())
  subject       String
  message       String
  recipientType String   @default("all")
  recipientCount Int     @default(0)
  sentBy        String
  createdAt     DateTime @default(now())
}

model FeeDiscount {
  id                Int               @id @default(autoincrement())
  schoolId          Int
  name              String
  description       String?
  discountType      String
  discountValue     Float
  applicableTo      String            @default("individual")
  className         String?
  active            Boolean           @default(true)
  isSiblingDiscount Boolean           @default(false)
  createdAt         DateTime          @default(now())
  school            School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentDiscounts  StudentDiscount[]

  @@index([schoolId])
  @@index([active])
}

model StudentDiscount {
  id         Int         @id @default(autoincrement())
  studentId  Int
  discountId Int
  appliedAt  DateTime    @default(now())
  appliedBy  String?
  student    Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  discount   FeeDiscount @relation(fields: [discountId], references: [id], onDelete: Cascade)

  @@unique([studentId, discountId])
  @@index([studentId])
  @@index([discountId])
}

model AcademicYear {
  id         Int       @id @default(autoincrement())
  schoolId   Int
  year       Int
  isActive   Boolean   @default(false)
  term1Start DateTime?
  term1End   DateTime?
  term2Start DateTime?
  term2End   DateTime?
  term3Start DateTime?
  term3End   DateTime?
  createdAt  DateTime  @default(now())
  school     School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, year])
  @@index([schoolId])
  @@index([schoolId, isActive])
}

model ExamFee {
  id              Int              @id @default(autoincrement())
  schoolId        Int
  name            String
  examType        String
  amount          Float
  targetClass     String
  academicYear    Int?
  dueDate         DateTime?
  active          Boolean          @default(true)
  createdAt       DateTime         @default(now())
  school          School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentExamFees StudentExamFee[]

  @@index([schoolId])
  @@index([schoolId, active])
}

model StudentExamFee {
  id          Int       @id @default(autoincrement())
  studentId   Int
  examFeeId   Int
  paid        Boolean   @default(false)
  paidAt      DateTime?
  paidAmount  Float?
  createdAt   DateTime  @default(now())
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  examFee     ExamFee   @relation(fields: [examFeeId], references: [id], onDelete: Cascade)

  @@unique([studentId, examFeeId])
  @@index([studentId])
  @@index([examFeeId])
}

model Testimonial {
  id              Int       @id @default(autoincrement())
  schoolId        Int       @unique
  quote           String?
  authorName      String?
  authorTitle     String?
  schoolName      String?
  rating          Int?
  approved        Boolean   @default(false)
  requestSentAt   DateTime?
  submittedAt     DateTime?
  createdAt       DateTime  @default(now())
  school          School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([approved])
}
